# =================================
# Bitig Configuration
# =================================

# API Authentication
API_KEY=change-me-to-a-secure-key

# Qdrant Vector Database
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=bitig

# LLM Provider: "ollama" or "claude"
LLM_PROVIDER=ollama

# Ollama (local LLM)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Claude API (optional, only if LLM_PROVIDER=claude)
CLAUDE_API_KEY=

# Embedding Model (sentence-transformers, runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# SQLite Database Path
SQLITE_PATH=data/bitig.db

# Gmail Connector
GMAIL_CREDENTIALS_PATH=

# Jira Connector
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Chunking Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64
